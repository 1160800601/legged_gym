<mujoco model="GR3Mini">
    <compiler angle="radian" meshdir="../meshes" autolimits="true"/>

    <default>
        <default class="GR3Mini">
            <geom group="2" type="mesh" contype="0" conaffinity="0"/>
            <joint type="hinge" armature="0.01" damping="0.01" frictionloss="0.01"/>

            <default class="collision">
                <geom group="3" rgba="0.7 0.7 0.7 0.5" contype="1" conaffinity="1"/>
            </default>

            <default class="motor_140E">
                <motor ctrllimited="true" ctrlrange="-140 140" gear="1"/>
            </default>
            <default class="motor_110E">
                <motor ctrllimited="true" ctrlrange="-110 110" gear="1"/>
            </default>
            <default class="motor_42E">
                <motor ctrllimited="true" ctrlrange="-42 42" gear="1"/>
            </default>
            <default class="motor_28E">
                <motor ctrllimited="true" ctrlrange="-28.5 28.5" gear="1"/>
            </default>
            <default class="motor_11E">
                <motor ctrllimited="true" ctrlrange="-11 11" gear="1"/>
            </default>
        </default>
    </default>

    <asset>
        <texture type="skybox" builtin="gradient" rgb1=".4 .5 .6" rgb2="0 0 0" width="800" height="800"/>
